{
  "manifest_version": 3,
  "name": "Student Servis Button",
  "version": "1.0",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.studentski-servis.com/*", "https://www.mjob.si/*"],
      "js": [
        "content.js",
        "reviewButtonVerified.js",
        "scraper.js",
		"auth.js"
      ]
    }
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",
	"https://*.firebaseapp.com/*",
    "https://*.firebaseio.com/*",
    "https://*.googleapis.com/*",
    "https://securetoken.googleapis.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["reviewPopup.html", "addReviewPopup.html", "auth.html", "popUpStyle.css", "popUpStyle-mjob.css", "Logos/LogoName.svg", "Logos/Logo.svg","Logos/Montserrat-Regular.woff"],
      "matches": ["<all_urls>"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "storage"
  ]
}